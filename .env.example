OPENAI_API_KEY=sk-your-key-here
# Optional Whisper model for audio transcription; default whisper-1
# WHISPER_MODEL=whisper-1

# Notion (required — every run creates a page under this parent)
# Create an integration at https://www.notion.so/my-integrations
# Share the parent page with the integration and paste its page ID here.
NOTION_API_KEY=secret_xxxxxxxx
NOTION_PARENT_PAGE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# SMTP (task emails). If SMTP_HOST is empty, emails are not sent.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_USE_TLS=true
